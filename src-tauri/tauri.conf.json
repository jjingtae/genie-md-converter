{
  "build": {
    "distDir": "../src",
    "devPath": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "지니 MD 변환기",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true,
        "save": true
      },
      "shell": {
        "open": true
      },
      "clipboard": {
        "writeText": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.genie.md-converter",
      "icon": [
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "targets": ["nsis"],
      "windows": {
        "nsis": {
          "installMode": "currentUser"
        }
      }
    },
    "windows": [
      {
        "title": "지니 MD 변환기",
        "width": 960,
        "height": 680,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 550
      }
    ]
  }
}
